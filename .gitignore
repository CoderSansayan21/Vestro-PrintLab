
# ---------- Environment files (NEVER commit) ----------
.env
.env.local
.env.production
.env.development
frontend/.env
frontend/.env.local
backend/.env
backend/.env.local

# ---------- Node / React (frontend) ----------
node_modules/
frontend/node_modules/
dist/
frontend/dist/
build/
.vite/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Python / FastAPI (backend) ----------
venv/
backend/venv/
.venv/
backend/.venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------- Alembic ----------
# Keep migration versions tracked — do NOT ignore backend/alembic/versions/

# ---------- Uploads (dev-only local storage) ----------
backend/app/uploads/*
!backend/app/uploads/.gitkeep

# ---------- Logs ----------
*.log
backend/app/logs/*
!backend/app/logs/.gitkeep

# ---------- 3D Model / Large Asset files (optional — uncomment if using Git LFS instead) ----------
# frontend/public/models/*.glb

# ---------- Database ----------
*.sqlite3
*.db
database/backups/*
!database/backups/.gitkeep

# ---------- OS files ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo

